DATABASE_URL=file:/home/z/my-project/db/custom.db

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
# PASOS PARA CONFIGURAR:
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea un proyecto o selecciona uno existente
# 3. Ve a "Credenciales" > "Crear credenciales" > "ID de cliente de OAuth 2.0"
# 4. Tipo de aplicación: "Aplicación web"
# 5. En "Orígenes de JavaScript autorizados", agrega tu dominio (ej: http://localhost:3000)
# 6. En "URI de redireccionamiento autorizado", agrega: http://localhost:3000/api/auth/callback/google
# 7. Copia el "ID de cliente" y pégalo abajo en GOOGLE_CLIENT_ID
# 8. Copia el "Secreto del cliente" y pégalo abajo en GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TMDB API Key (get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# User passwords (optional - defaults: admin123, hele123, usuario123)
ADMIN_PASSWORD=
HELE_PASSWORD=
USUARIO_PASSWORD=

# Xuper TV 3DES encryption key (optional - has known fallback)
# Generate with: openssl rand -base64 24
XUPER_DES_KEY=

# Admin emails for Google OAuth (comma-separated)
# Default: yecos11@gmail.com
ADMIN_EMAILS=
