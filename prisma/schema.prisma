// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== IPTV GUARDIAN - Sistema de validación automática =====

/// Cada fuente M3U que el Guardian monitorea
model GuardianSource {
  id        String   @id @default(cuid())
  name      String                          // Nombre descriptivo (ej: "Colombia", "Deportes")
  url       String                          // URL del playlist M3U
  type      String   @default("m3u")        // "m3u" | "xtream"
  category  String   @default("country")    // "country" | "category" | "extra" | "xtream"
  enabled   Boolean  @default(true)
  priority  Int      @default(0)            // Mayor = más prioritario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Historial de cada escaneo completo
model GuardianScan {
  id              String   @id @default(cuid())
  status          String   @default("running") // "running" | "completed" | "failed"
  totalSources    Int      @default(0)
  totalChannels   Int      @default(0)
  workingChannels Int      @default(0)
  failedChannels  Int      @default(0)
  durationMs      Int      @default(0)
  error           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  trigger         String   @default("scheduled") // "scheduled" | "manual"
}

/// Fuentes descubiertas por los 4 motores del Discovery
/// Tipos: "web" (búsqueda general), "github" (scanner GitHub), "scraped" (deep scraping), "xtream" (probing)
model DiscoveredSource {
  id              String   @id @default(cuid())
  url             String   @unique              // URL del M3U (única)
  name            String   @default("")         // Nombre del sitio/página donde se encontró
  sourceUrl       String   @default("")         // URL de la página que la contenía
  discoveryEngine String   @default("web")      // "web" | "github" | "scraped" | "xtream"
  channelCount    Int      @default(0)          // Canales encontrados en la última validación
  isValid         Boolean  @default(false)      // Si la URL devuelve un M3U válido
  addedToGuardian Boolean  @default(false)      // Si fue promovida al Guardian
  lastChecked     DateTime @default(now())       // Última vez que se verificó
  createdAt       DateTime @default(now())
}

/// Canales verificados como funcionales (se limpia y regenera cada escaneo)
model VerifiedChannel {
  id        String   @id @default(cuid())
  scanId    String                        // ID del último scan que verificó este canal
  sourceId  String                        // ID de la fuente de origen
  name      String
  logo      String   @default("")
  group     String   @default("General")
  url       String   @unique              // URL del stream (única para deduplicar)
  country   String   @default("")
  quality   String   @default("SD")
  playlist  String   @default("")         // ID del playlist original (ej: "co", "sports")
  createdAt DateTime @default(now())
}

// ===== XUPER TV - Cliente de acceso directo =====

/// Sesiones activas del cliente Xuper TV
model XuperSession {
  id            String   @id @default(cuid())
  userId        String                        // ID del usuario Xuper
  username      String                        // Username en Xuper
  token         String                        // Token de sesión (encriptado)
  portalDomain  String   @default("")         // Dominio portal activo
  vipLevel      Int      @default(0)          // Nivel VIP
  expireTime    String   @default("")         // Fecha de expiración
  isActive      Boolean  @default(true)       // Sesión activa
  lastHeartbeat DateTime @default(now())       // Último heartbeat exitoso
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Resultados del monitoreo Xuper
model XuperMonitorLog {
  id              String   @id @default(cuid())
  dcsAvailable    Boolean  @default(false)     // DCS respondió
  domainsChecked  Int      @default(0)         // Total dominios chequeados
  domainsOk       Int      @default(0)         // Dominios OK
  portalLatencyMs Int      @default(0)         // Latencia del portal
  configOk        Boolean  @default(false)     // Config endpoint OK
  details         String   @default("{}")      // JSON con detalles por dominio
  createdAt       DateTime @default(now())
}
