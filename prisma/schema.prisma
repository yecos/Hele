// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== NEXTAUTH - Modelos requeridos por NextAuth con Prisma Adapter =====

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")   // "admin" | "user"
  provider      String    @default("credentials") // "google" | "credentials"
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== IPTV GUARDIAN - Sistema de validación automática =====

/// Cada fuente M3U que el Guardian monitorea
model GuardianSource {
  id        String   @id @default(cuid())
  name      String                          // Nombre descriptivo (ej: "Colombia", "Deportes")
  url       String                          // URL del playlist M3U
  type      String   @default("m3u")        // "m3u" | "xtream"
  category  String   @default("country")    // "country" | "category" | "extra" | "xtream"
  enabled   Boolean  @default(true)
  priority  Int      @default(0)            // Mayor = más prioritario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Historial de cada escaneo completo
model GuardianScan {
  id              String   @id @default(cuid())
  status          String   @default("running") // "running" | "completed" | "failed"
  totalSources    Int      @default(0)
  totalChannels   Int      @default(0)
  workingChannels Int      @default(0)
  failedChannels  Int      @default(0)
  durationMs      Int      @default(0)
  error           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  trigger         String   @default("scheduled") // "scheduled" | "manual"
}

/// Fuentes descubiertas por los 4 motores del Discovery
/// Tipos: "web" (búsqueda general), "github" (scanner GitHub), "scraped" (deep scraping), "xtream" (probing)
model DiscoveredSource {
  id              String   @id @default(cuid())
  url             String   @unique              // URL del M3U (única)
  name            String   @default("")         // Nombre del sitio/página donde se encontró
  sourceUrl       String   @default("")         // URL de la página que la contenía
  discoveryEngine String   @default("web")      // "web" | "github" | "scraped" | "xtream"
  channelCount    Int      @default(0)          // Canales encontrados en la última validación
  isValid         Boolean  @default(false)      // Si la URL devuelve un M3U válido
  addedToGuardian Boolean  @default(false)      // Si fue promovida al Guardian
  lastChecked     DateTime @default(now())       // Última vez que se verificó
  createdAt       DateTime @default(now())
}

/// Canales verificados como funcionales (se limpia y regenera cada escaneo)
model VerifiedChannel {
  id        String   @id @default(cuid())
  scanId    String                        // ID del último scan que verificó este canal
  sourceId  String                        // ID de la fuente de origen
  name      String
  logo      String   @default("")
  group     String   @default("General")
  url       String   @unique              // URL del stream (única para deduplicar)
  country   String   @default("")
  quality   String   @default("SD")
  playlist  String   @default("")         // ID del playlist original (ej: "co", "sports")
  createdAt DateTime @default(now())
}

// ===== XUPER TV MONITOR - Monitoreo de infraestructura Xuper TV =====

/// Snapshots de dominios Xuper TV con estado e IPs
model XuperDomainSnapshot {
  id           String   @id @default(cuid())
  domain       String
  service      String                        // "portal" | "epg" | "notice" | "bigbee" | "ads" | "h5" | "upgrade" | "cdn" | "download"
  role         String   @default("primary")  // "primary" | "backup"
  ipAddresses  String   @default("[]")       // JSON array of IPs
  isUp         Boolean  @default(false)
  responseMs   Int      @default(0)
  checkedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
}

/// Respuestas del DCS (Domain Configuration Service)
model XuperDCSResponse {
  id          String   @id @default(cuid())
  rawData     String
  domainCount Int      @default(0)
  changed     Boolean  @default(false)
  diffSummary String?
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
}

/// Alertas del monitor Xuper TV
model XuperAlert {
  id          String   @id @default(cuid())
  type        String                        // "domain_change" | "endpoint_down" | "dcs_change"
  severity    String                        // "critical" | "warning" | "info"
  title       String
  description String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ===== XUPER TV CLIENT - Cliente para acceder a los servidores =====

/// Sesiones de Xuper TV (tokens de autenticación)
model XuperSession {
  id        String   @id @default(cuid())
  token     String                        // Token de autenticación
  userId    String                        // ID del usuario
  domain    String                        // Dominio del servidor
  authType  String   @default("sn")       // "sn" | "email" | "device"
  isActive  Boolean  @default(true)       // Si la sesión está activa
  expiresAt DateTime?                     // Fecha de expiración (si aplica)
  createdAt DateTime @default(now())
}

/// Log de llamadas API a Xuper TV
model XuperAPILog {
  id          String   @id @default(cuid())
  endpoint    String                        // Path del endpoint
  method      String   @default("POST")     // HTTP method
  domain      String                        // Dominio usado
  statusCode  Int      @default(0)          // HTTP status code
  responseMs  Int      @default(0)          // Tiempo de respuesta
  encrypted   Boolean  @default(false)      // Si la request usó encriptación
  success     Boolean  @default(false)      // Si la llamada fue exitosa
  error       String?                       // Error si falló
  triggeredBy String   @default("manual")   // "manual" | "scheduled" | "auto"
  createdAt   DateTime @default(now())
}
