# ===========================================
# XuperStream - Environment Variables
# ===========================================
# Copy this file as .env.local and fill in the values

# TMDB API (required for movie/series metadata)
# Get your free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Database - PostgreSQL via Neon (for production deployment)
# Create a free database at: https://neon.tech
# DATABASE_URL = pooled connection (for app runtime)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&pgbouncer=true
# DIRECT_DATABASE_URL = direct connection (for migrations/seed)
DIRECT_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Database - SQLite (for local development only)
# DATABASE_URL=file:./db/custom.db

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Optional: App URL (for CORS and redirects)
NEXT_PUBLIC_APP_URL=https://your-domain.com
